{
  "name": "@dust2dust-backend/midnight-contracts",
  "version": "0.1.0",
  "exports": {
    "./game2": "./contract-game2/src/index.ts"
  },
  "tasks": {
    "midnight-node:start": "MIDNIGHT_STORAGE_PASSWORD=YourPasswordMy1! CFG_PRESET=dev deno run -A --unstable-detect-cjs @paimaexample/npm-midnight-node --dev --rpc-port 9944 --state-pruning archive --blocks-pruning archive --public-addr /ip4/127.0.0.1 --unsafe-rpc-external",
    "midnight-node:wait": "wait-on tcp:9944",
    "midnight-indexer:start": "RUST_BACKTRACE=1 LEDGER_NETWORK_ID=\"Undeployed\" SUBSTRATE_NODE_WS_URL=\"ws://localhost:9944\" APP__INFRA__SECRET=$(openssl rand -hex 32 | tr 'a-f' 'A-F') FEATURES_WALLET_ENABLED=\"true\" APP__INFRA__NODE__URL=\"ws://localhost:9944\" deno run -A --unstable-detect-cjs @paimaexample/npm-midnight-indexer --binary --clean",
    "midnight-indexer:wait": "wait-on tcp:8088",
    "midnight-proof-server:start": "RUST_BACKTRACE=full SUBSTRATE_NODE_WS_URL=\"ws://localhost:9944\" deno run -A --unstable-detect-cjs @paimaexample/npm-midnight-proof-server",
    "midnight-proof-server:wait": "wait-on tcp:6300",
    "midnight-contract:clean": "rm -rf midnight-level-db",
    "compact": "cd contract-game2 && npm run compact",
    "midnight-contract:deploy": "deno task contract-game2:deploy",
    "contract-game2:deploy": "deno --unstable-detect-cjs -A contract-game2-deploy.ts",
    "contract-game2:deploy:dev": "MIDNIGHT_NETWORK_ID=undeployed deno --unstable-detect-cjs -A contract-game2-deploy.ts",
    "contract-game2:deploy:testnet": "MIDNIGHT_NETWORK_ID=preprod deno --unstable-detect-cjs -A contract-game2-deploy.ts",
    "contract-game2:deploy:mainnet": "MIDNIGHT_NETWORK_ID=mainnet deno --unstable-detect-cjs -A contract-game2-deploy.ts",
    "contract-game2:admin": "deno --unstable-detect-cjs -A contract-game2-admin.ts",
    "contract-game2:test": "deno --unstable-detect-cjs -A contract-game2-test.ts",
    "contract-game2:test:dev": "MIDNIGHT_NETWORK_ID=undeployed deno --unstable-detect-cjs -A contract-game2-test.ts",
    "contract-game2:admin:dev": "MIDNIGHT_NETWORK_ID=undeployed deno --unstable-detect-cjs -A contract-game2-admin.ts",
    "contract-game2:admin:testnet": "MIDNIGHT_NETWORK_ID=preprod deno --unstable-detect-cjs -A contract-game2-admin.ts",
    "contract-game2:admin:mainnet": "MIDNIGHT_NETWORK_ID=mainnet deno --unstable-detect-cjs -A contract-game2-admin.ts",
    "contract-game2:patch-frontend": "deno --unstable-detect-cjs -A contract-game2-deploy.ts patch-frontend-env",
    "contract-game2:patch-frontend:dev": "MIDNIGHT_NETWORK_ID=undeployed deno --unstable-detect-cjs -A contract-game2-deploy.ts patch-frontend-env",
    "contract-game2:patch-frontend:testnet": "MIDNIGHT_NETWORK_ID=preprod deno --unstable-detect-cjs -A contract-game2-deploy.ts patch-frontend-env",
    "contract-game2:patch-frontend:mainnet": "MIDNIGHT_NETWORK_ID=mainnet deno --unstable-detect-cjs -A contract-game2-deploy.ts patch-frontend-env"
  },
  "imports": {
    "@paimaexample/npm-midnight-node": "npm:@paimaexample/npm-midnight-node@0.10.24",
    "@paimaexample/npm-midnight-indexer": "npm:@paimaexample/npm-midnight-indexer@0.10.24",
    "@paimaexample/npm-midnight-proof-server": "npm:@paimaexample/npm-midnight-proof-server@0.10.24",
    "@midnight-ntwrk/compact-runtime": "npm:@midnight-ntwrk/compact-runtime@0.15.0",
    "@midnight-ntwrk/ledger-v8": "npm:@midnight-ntwrk/ledger-v8@8.0.3",
    "@midnight-ntwrk/midnight-js-contracts": "npm:@midnight-ntwrk/midnight-js-contracts@4.0.2",
    "@midnight-ntwrk/midnight-js-indexer-public-data-provider": "npm:@midnight-ntwrk/midnight-js-indexer-public-data-provider@4.0.2",
    "@midnight-ntwrk/midnight-js-level-private-state-provider": "npm:@midnight-ntwrk/midnight-js-level-private-state-provider@4.0.2",
    "@midnight-ntwrk/midnight-js-network-id": "npm:@midnight-ntwrk/midnight-js-network-id@4.0.2",
    "@midnight-ntwrk/midnight-js-node-zk-config-provider": "npm:@midnight-ntwrk/midnight-js-node-zk-config-provider@4.0.2",
    "@midnight-ntwrk/midnight-js-types": "npm:@midnight-ntwrk/midnight-js-types@4.0.2",
    "@midnight-ntwrk/midnight-js-http-client-proof-provider": "npm:@midnight-ntwrk/midnight-js-http-client-proof-provider@4.0.2",
    "@midnight-ntwrk/midnight-js-utils": "npm:@midnight-ntwrk/midnight-js-utils@4.0.2",
    "@midnight-ntwrk/wallet-sdk-abstractions": "npm:@midnight-ntwrk/wallet-sdk-abstractions@2.0.0",
    "@midnight-ntwrk/wallet-sdk-address-format": "npm:@midnight-ntwrk/wallet-sdk-address-format@3.1.0",
    "@midnight-ntwrk/wallet-sdk-facade": "npm:@midnight-ntwrk/wallet-sdk-facade@3.0.0",
    "@midnight-ntwrk/wallet-sdk-hd": "npm:@midnight-ntwrk/wallet-sdk-hd@3.0.1",
    "@midnight-ntwrk/wallet-sdk-shielded": "npm:@midnight-ntwrk/wallet-sdk-shielded@2.1.0",
    "@midnight-ntwrk/wallet-sdk-dust-wallet": "npm:@midnight-ntwrk/wallet-sdk-dust-wallet@3.0.0",
    "@midnight-ntwrk/wallet-sdk-unshielded-wallet": "npm:@midnight-ntwrk/wallet-sdk-unshielded-wallet@2.1.0",
    "@std/path": "jsr:@std/path",
    "@std/fs": "jsr:@std/fs",
    "rxjs": "npm:rxjs@^7.8.2",
    "ws": "npm:ws",
    "commander": "npm:commander@^12.0.0",
    "pino": "npm:pino@^8.16.0",
    "pino-pretty": "npm:pino-pretty@^10.2.3",
    "@midnight-ntwrk/compact-js": "npm:@midnight-ntwrk/compact-js@2.5.0",
    "game2-contract": "./frontend-libs/game2-contract/index.js",
    "game2-api": "./frontend-libs/game2-api/index.js"
  }
}

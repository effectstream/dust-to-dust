{
  "workspace": [
    "./packages/**/*"
  ],
  "nodeModulesDir": "auto",
  "tasks": {
    "build:midnight": "deno task -f @dust2dust-backend/midnight-contracts compact",
    "dev": "deno task -f @dust2dust-backend/node dev",
    "testnet": "deno task -f @dust2dust-backend/node testnet",
    "mainnet": "deno task -f @dust2dust-backend/node mainnet",
    "check:dev": "deno task -f @dust2dust-backend/node check:dev",
    "check:testnet": "deno task -f @dust2dust-backend/node check:testnet",
    "check:mainnet": "deno task -f @dust2dust-backend/node check:mainnet"
  },
  "imports": {
    "@paimaexample/tui": "jsr:@paimaexample/tui@0.10.24",
    "@paimaexample/midnight-contracts": "jsr:@paimaexample/midnight-contracts@0.10.24",
    "@paimaexample/evm-contracts": "jsr:@paimaexample/evm-contracts@0.10.24",
    "wait-on": "npm:wait-on@^9.0.4"
  },
  "lint": {
    "rules": {
      "exclude": [
        "no-this-alias",
        "require-yield",
        "no-explicit-any",
        "ban-types",
        "no-unused-vars",
        "no-slow-types"
      ]
    }
  },
  "allowScripts": ["npm:classic-level@3.0.0", "npm:cpu-features@0.0.10", "npm:esbuild@0.27.3", "npm:fsevents@2.3.3", "npm:msgpackr-extract@3.0.3", "npm:protobufjs@7.5.4", "npm:ssh2@1.17.0"]
}